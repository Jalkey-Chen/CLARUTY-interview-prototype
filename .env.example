# CLARITY Patient Explainer Dashboard environment template
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# The current prototype does not call external APIs. These variables document
# the intended configuration points for future API-backed Steps 1-4.

# Live API calls are disabled by default so copied template endpoints do not
# produce connection errors. Set to true only after real backend endpoints exist.
CLARITY_ENABLE_API_CALLS=false

# Step 1 / shared service configuration
CLARITY_ENV=local
NOTE_INGESTION_API_URL=

# Step 2: fact extraction from imported clinical note
FACT_EXTRACTION_API_URL=

# Step 3: style-controlled script generation and verification
SCRIPT_GENERATION_API_URL=
VERIFICATION_API_URL=

# Step 4: verified video generation and cached video retrieval
VIDEO_GENERATION_API_URL=
VIDEO_CACHE_DIR=videos

# Provider keys for future integrations. Do not commit real keys.
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=

# Optional model/provider defaults for future prompt execution
LLM_MODEL=replace-with-selected-model
SCRIPT_LANGUAGE_DEFAULT=en
