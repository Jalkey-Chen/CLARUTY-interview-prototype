# Keep source-controlled placeholder directories, but avoid committing large generated media by default.
videos/*.mp4
videos/*.mov
videos/*.webm
!videos/.gitkeep

# Experimental notebook outputs can contain generated clinical text and should
# stay local unless they have been reviewed and intentionally de-identified.
experiments/**/outputs/
